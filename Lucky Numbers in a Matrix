class Solution:
    def luckyNumbers(self, matrix: List[List[int]]) -> List[int]:

        ans = []

        rows = len(matrix)
        cols = len(matrix[0])

        for i in range(rows):
            row_min = min(matrix[i])
            col_index = matrix[i].index(row_min)

            col_max = max(matrix[r][col_index] for r in range(rows))

            if row_min == col_max:
                ans.append(row_min)

        return ans
