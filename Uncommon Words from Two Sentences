class Solution:
    def uncommonFromSentences(self, s1: str, s2: str) -> List[str]:
        l1 = s1.split()
        l2 = s2.split()

        s1 = set(l1)
        s2 = set(l2)

        l5 = []
        for i in s1:
            if i not in s2 and l1.count(i) == 1:
                l5.append(i)
        for i in s2:
            if i not in s1 and l2.count(i) == 1:
                l5.append(i)
        return l5
