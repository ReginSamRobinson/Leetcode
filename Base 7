class Solution:
    def convertToBase7(self, num: int) -> str:
        if num == 0:
            return "0"

        negative = num < 0
        n = abs(num)
        result = ""

        while n > 0:
            result = str(n % 7) + result
            n //= 7

        if negative:
            result = "-" + result

        return result
