class Solution:
    def isHappy(self, n: int) -> bool:
        if n==1:
            return True
        s1=n
        if len(str(s1))==1:
            s1=n*n
        
        while s1!=1 and s1!=4 :
            s=0
            s2=str(s1)
            for i in range(len(s2)):
                s+=int(s2[i])*int(s2[i])
            s1=s
        if s1==1:
            return True
        else:
            return False
