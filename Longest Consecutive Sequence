class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        l = sorted(set(nums))
        c = 1
        m = 1

        if len(l)==0:
            return 0

        for i in range(len(l)-1):
            if l[i]+1 == l[i+1]:  
                c += 1
            else:                 
                c = 1
            m = max(m, c)
        return m
